# StackGG — PRODUCTION environment template (Railway).
# Copy each value into the Railway service "Variables" tab. NEVER commit real secrets.

# --- Database ---
# Add the Railway Postgres plugin and reference its var, e.g. ${{ Postgres.DATABASE_URL }}
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME

# --- Auth: signs sessions + magic-link tokens ---
# Generate a strong value with:  openssl rand -hex 32
AUTH_SECRET=replace-with-openssl-rand-hex-32

# --- Public URL: builds magic/invite links AND gates Secure cookies (https => Secure on) ---
# Must be set BEFORE the web build (NEXT_PUBLIC_* is inlined at build time).
NEXT_PUBLIC_BASE_URL=https://stackgg.app

# --- Riot API (production key from https://developer.riotgames.com) ---
RIOT_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DEFAULT_PLATFORM=euw1

# --- Email magic links (Resend) ---
MAGIC_LINK_TRANSPORT=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
MAGIC_LINK_FROM=StackGG <no-reply@stackgg.app>

NODE_ENV=production
