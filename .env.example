# Riot API key (development keys expire ~24h; regenerate at https://developer.riotgames.com)
RIOT_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Postgres
DATABASE_URL=postgres://localhost:5432/crewstats
DATABASE_URL_TEST=postgres://localhost:5432/crewstats_test

# Default region (single-region launch; EUW)
DEFAULT_PLATFORM=euw1

# Auth: secret used to sign session + magic-link tokens
AUTH_SECRET=dev-secret-change-me-in-production

# Public base URL (used to build invite + magic links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Magic-link delivery: "console" (default — logs the link to the server console for
# local dev) or "resend" (emails the link via Resend's HTTP API; set the two vars below).
MAGIC_LINK_TRANSPORT=console
# Resend API key — get one free at https://resend.com (needed when TRANSPORT=resend)
RESEND_API_KEY=
# From address. The shared "onboarding@resend.dev" works immediately for testing; for
# production use an address on a domain you've verified in Resend (e.g. "StackGG <no-reply@yourdomain.com>").
MAGIC_LINK_FROM=StackGG <onboarding@resend.dev>
